# Local development — copy to .dev.vars for Wrangler worker vars (runtime)
ENVIRONMENT=development
MOCK_SOURCES=true
AI_FALLBACK_MODE=false
VECTORIZE_FALLBACK_MODE=true
AI_GATEWAY_ENABLED=true
AI_GATEWAY_ACCOUNT_ID=4c15704ef706b9c8954cd6f9feb678d8
AI_GATEWAY_ID=wc-tactical
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Deploy CLI auth — create cf-deploy.token in project root (gitignored)
# Get token: https://dash.cloudflare.com/profile/api-tokens

# REQUIRED for OpenAI via Cloudflare AI Gateway (never commit real keys)
OPENAI_API_KEY=sk-your-openai-key

# Optional: Cloudflare API token if AI Gateway requires authentication
# CF_AIG_TOKEN=

# Optional admin token (backend ops only)
# ADMIN_TOKEN=change-me-in-production
